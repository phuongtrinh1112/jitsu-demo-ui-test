# Network SSL/TLS Configuration
# If behind a corporate proxy with self-signed certificates, set:
# NODE_TLS_REJECT_UNAUTHORIZED=0

# This is automatically set by npm scripts (test, test:chromium, test:firefox, test:headed, test:debug)
# but you can also set it manually if running Playwright commands directly:
# export NODE_TLS_REJECT_UNAUTHORIZED=0
# npx playwright test
